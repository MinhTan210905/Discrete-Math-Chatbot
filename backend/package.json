{
  "name": "discrete-math-chatbot-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "build:bank": "python ../data/build_question_bank.py",
    "prepare:data": "python ../data/build_question_bank.py && python ../data/prepare_train_data.py",
    "train:model": "python ../data/train_model.py",
    "rebuild:data": "python ../data/build_question_bank.py && python ../data/prepare_train_data.py && python ../data/train_model.py",
    "test": "node --test ./tests/*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "openai": "^6.32.0"
  }
}
