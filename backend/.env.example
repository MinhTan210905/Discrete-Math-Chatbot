# =========================================================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG CHO CHATBOT TOÁN RỜI RẠC (BACKEND)
# =========================================================================

# Cổng khởi chạy Server Node.js
PORT=3001

# Chế độ chạy mặc định (options: "traditional" hoặc "rag")
CHAT_MODE=traditional

# Đường dẫn đến cơ sở dữ liệu SQLite
CHAT_DB_PATH=../data/chatbot.sqlite

# --- Cấu hình cho RAG AI (Groq / OpenAI) ---

# API Key cho OpenAI hoặc Groq (Bắt buộc nếu chạy chế độ RAG)
OPENAI_API_KEY=

# Base URL (Bỏ trống nếu dùng OpenAI, điền url dưới nếu dùng Groq)
# Ví dụ cho Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=

# Tên mô hình AI sử dụng
# Ví dụ OpenAI: gpt-4o-mini hoặc gpt-4o
# Ví dụ Groq: llama-3.3-70b-versatile hoặc llama3-8b-8192
OPENAI_CHAT_MODEL=gpt-4o-mini
