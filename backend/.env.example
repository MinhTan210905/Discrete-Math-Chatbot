# =============================================
# Copy file này thành .env rồi điền thông tin
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env (Windows)
# =============================================

# --- OpenAI / Groq API Key ---
# Bỏ trống nếu chỉ dùng mode Traditional (không cần key)
# OpenAI: lấy key tại https://platform.openai.com/api-keys
# Groq (miễn phí): lấy key tại https://console.groq.com
OPENAI_API_KEY=

# --- Model chat ---
# OpenAI: gpt-4o-mini | gpt-4o
# Groq:   llama-3.3-70b-versatile | mixtral-8x7b-32768
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Base URL ---
# Để trống = dùng OpenAI
# Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=

# --- Embedding model (chỉ dùng cho RAG với OpenAI) ---
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Server ---
PORT=3001

# --- Database SQLite ---
CHAT_DB_PATH=../data/chatbot.sqlite

# --- Giới hạn context ---
MAX_CONTEXT_MESSAGES=10
MAX_RETRIEVED_DOCS=5
MAX_OUTPUT_TOKENS=900
